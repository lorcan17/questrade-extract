# questrade-extract — example env file. Copy to .env for local dev.
# On NixOS systemd sets STATE_DIRECTORY automatically.

# Path to the Questrade token file (default: ~/.config/questrade/token)
# QUESTRADE_TOKEN_FILE=~/.config/questrade/token

# Path to the SQLite database (default: ./db/questrade.db)
# QUESTRADE_DB_PATH=./db/questrade.db
